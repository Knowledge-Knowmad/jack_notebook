rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 卡片資料：任何人可讀，僅白名單 email 可寫
    match /cards/{cardId} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.email in ['knowledge.nomads.tw2@gmail.com', 'foxfirejack@gmail.com'];
    }
  }
}
